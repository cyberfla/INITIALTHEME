{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .zebraa1t-test-{{ section.id }} {
    background: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
  }

  .zebraa1t-test-{{ section.id }} .zebraa1t-test__inner {
    text-align: {{ section.settings.text_alignment }};
  }

  .zebraa1t-test-{{ section.id }} .zebraa1t-test__eyebrow {
    margin: 0 0 1rem;
    font-size: 1.3rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .zebraa1t-test-{{ section.id }} .zebraa1t-test__heading {
    margin: 0;
    color: inherit;
  }

  .zebraa1t-test-{{ section.id }} .zebraa1t-test__text {
    max-width: 72rem;
    margin-top: 1.6rem;
  }

  .zebraa1t-test-{{ section.id }} .zebraa1t-test__inner--center .zebraa1t-test__text {
    margin-left: auto;
    margin-right: auto;
  }

  .zebraa1t-test-{{ section.id }} .zebraa1t-test__inner--right .zebraa1t-test__text {
    margin-left: auto;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="zebraa1t-test zebraa1t-test-{{ section.id }} section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="zebraa1t-test__inner zebraa1t-test__inner--{{ section.settings.text_alignment }}">
      {%- if section.settings.eyebrow != blank -%}
        <p class="zebraa1t-test__eyebrow">
          {{ section.settings.eyebrow | escape }}
        </p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="zebraa1t-test__heading {{ section.settings.heading_size }}">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="zebraa1t-test__text rte">
          {{ section.settings.text }}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "ZEBRAA1tTest",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Theme test section"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "ZEBRAA1tTest"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>This section was added for customizer testing.</p>"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        }
      ],
      "default": "h1"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f4f4f4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "ZEBRAA1tTest"
    }
  ]
}
{% endschema %}
